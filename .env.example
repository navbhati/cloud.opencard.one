NEXT_PUBLIC_SOURCE_ADDITION_COST=
NEXT_PUBLIC_CHAT_MESSAGE_COST=
NEXT_PUBLIC_INFOGRAPHIC_TRANSFORM_COST=

# Redis Cache Configuration
# Options: upstash, azure, standard
REDIS_PROVIDER=

# Upstash Redis (for Vercel/serverless) - production
# Get these from the Upstash dashboard: https://console.upstash.com/vercel/kv/9d70721f-eac2-4cc5-86e9-4d0697ad9622 (login via vercel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Standard Redis (for Azure/self-hosted) - production
# Format: redis://username:password@hostname:port or rediss:// for TLS
REDIS_URL=

# Free referral credits 
NEXT_PUBLIC_REFERRAL_FREE_CREDITS=

# vercel blob 
BLOB_READ_WRITE_TOKEN=

# this won't be needed inproduction
